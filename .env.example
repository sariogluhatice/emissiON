# ── Database ────────────────────────────────────────────────
# DB_HOST must be "db" inside Docker, "localhost" for local dev.
DB_HOST=db
DB_PORT=5432
DB_NAME=emission_db
DB_USER=your_db_username
DB_PASSWORD=your_db_password

# ── JWT ─────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_random_secret_string
JWT_EXPIRES_IN=7d

PORT=3000

# ── AI / External APIs ──────────────────────────────────────
# Leave blank to disable each service; the app degrades gracefully.
CLIMATIQ_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
GEMINI_API_KEY2=
GEMINI_API_KEY3=

# ── AWS Textract (invoice OCR) ───────────────────────────────
# Leave all blank to disable OCR; manual entry still works.
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
# AWS_SESSION_TOKEN=

# ── Email / SMTP ─────────────────────────────────────────────
# Leave SMTP_USER and SMTP_PASS blank to enable mock mode:
# verification codes and password-reset links are printed to the
# server console instead of being emailed (safe for local dev).
#
# For real email: create a Gmail App Password at
# https://myaccount.google.com/apppasswords and fill in below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=emissiON <noreply@emission.app>
