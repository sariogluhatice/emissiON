DB_HOST=db
DB_PORT=5432
DB_NAME=emission_db
DB_USER=your_username
DB_PASSWORD=your_password

JWT_SECRET=change_this_to_a_random_secret
JWT_EXPIRES_IN=7d

PORT=3000

# Climatiq API (Carbon Emission Calculation)
CLIMATIQ_API_KEY=your_climatiq_api_key_here
